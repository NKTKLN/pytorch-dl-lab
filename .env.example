# Telegram notifications (dl_roadmap.utils.notify)
# Bot token from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=123456789:AAExampleBotTokenReplaceMe
# Chat id to send notifications to (e.g. from @userinfobot)
TELEGRAM_CHAT_ID=123456789
# Optional proxy for reaching api.telegram.org (http:// or socks5://,
# socks5 requires the `pysocks` package)
# TELEGRAM_PROXY=socks5://user:pass@host:port
